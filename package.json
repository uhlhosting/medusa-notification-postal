{
  "name": "@uhlhosting/medusa-notification-postal",
  "version": "0.1.0",
  "description": "Postal notification provider for Medusa",
  "author": "uhlhosting",
  "private": true,
  "license": "UNLICENSED",
  "files": [
    ".medusa/server"
  ],
  "main": "./.medusa/server/src/index.js",
  "types": "./.medusa/server/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./.medusa/server/src/index.d.ts",
      "default": "./.medusa/server/src/index.js"
    },
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/postal": {
      "types": "./.medusa/server/src/modules/postal/index.d.ts",
      "default": "./.medusa/server/src/modules/postal/index.js"
    },
    "./.medusa/server/src/providers/*": "./.medusa/server/src/providers/*/index.js",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./.medusa/server/src/*": "./.medusa/server/src/*",
    "./*": "./.medusa/server/src/*.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    }
  },
  "keywords": [
    "medusa",
    "plugin",
    "medusa-plugin",
    "medusa-v2",
    "notification",
    "notification-provider",
    "postal",
    "email"
  ],
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "prepublishOnly": "medusa plugin:build",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "5.64.2",
    "i18next": "26.3.0",
    "nodemailer": "^6.10.1",
    "pg": "8.21.0",
    "react-i18next": "13.5.0",
    "react-router-dom": "6.30.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@medusajs/admin-sdk": "2.16.0",
    "@medusajs/admin-shared": "2.16.0",
    "@medusajs/cli": "2.16.0",
    "@medusajs/framework": "2.16.0",
    "@medusajs/icons": "2.16.0",
    "@medusajs/medusa": "2.16.0",
    "@medusajs/test-utils": "2.16.0",
    "@medusajs/types": "2.16.0",
    "@medusajs/ui": "4.1.16",
    "@swc/core": "^1.15.41",
    "@types/node": "20.19.26",
    "@types/nodemailer": "^6.4.24",
    "@types/react": "^18.3.31",
    "@types/react-dom": "18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^9.39.4",
    "prop-types": "^15.8.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "ts-node": "^10.9.2",
    "typescript": "5.6.2",
    "vite": "^5.4.21",
    "yalc": "1.0.0-pre.53"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "2.16.0",
    "@medusajs/cli": "2.16.0",
    "@medusajs/framework": "2.16.0",
    "@medusajs/icons": "2.16.0",
    "@medusajs/medusa": "2.16.0",
    "@medusajs/test-utils": "2.16.0",
    "@medusajs/ui": "4.1.16"
  },
  "engines": {
    "node": ">=20"
  }
}
