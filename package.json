{
  "name": "@uhlhosting/medusa-notification-postal",
  "version": "0.1.0",
  "description": "Postal notification provider for Medusa",
  "author": "uhlhosting",
  "license": "UNLICENSED",
  "files": [
    ".medusa/server"
  ],
  "main": "./.medusa/server/src/index.js",
  "exports": {
    ".": {
      "types": "./.medusa/server/src/index.d.ts",
      "default": "./.medusa/server/src/index.js"
    },
    "./package.json": "./package.json",
    "./.medusa/server/src/modules/postal/index.js": "./.medusa/server/src/modules/postal/index.js",
    "./.medusa/server/src/modules/postal": "./.medusa/server/src/modules/postal/index.js",
    "./.medusa/server/src/modules/postal/index": "./.medusa/server/src/modules/postal/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/*": "./.medusa/server/src/modules/*/index.js",
    "./.medusa/server/src/*": "./.medusa/server/src/*",
    "./*": "./.medusa/server/src/*.js",
    "./modules/postal": {
      "types": "./.medusa/server/src/modules/postal/index.d.ts",
      "default": "./.medusa/server/src/modules/postal/index.js"
    },
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    },
    "./providers/*": "./.medusa/server/src/providers/*/index.js"
  },
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "prepublishOnly": "medusa plugin:build"
  },
  "keywords": [
    "medusa-provider",
    "notification",
    "postal"
  ],
  "dependencies": {
    "@medusajs/framework": "2.15.3",
    "@tanstack/react-query": "5.64.2",
    "nodemailer": "^6.10.1"
  },
  "devDependencies": {
    "@medusajs/admin-sdk": "2.15.3",
    "@medusajs/admin-shared": "2.15.3",
    "@medusajs/cli": "2.15.3",
    "@medusajs/framework": "2.15.3",
    "@medusajs/types": "2.15.3",
    "@medusajs/ui": "4.1.13",
    "@types/node": "20.19.26",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "6.30.3",
    "typescript": "5.6.2"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "2.15.3",
    "@medusajs/cli": "2.15.3",
    "@medusajs/framework": "2.15.3",
    "@medusajs/icons": "2.15.3",
    "@medusajs/medusa": "2.15.3",
    "@medusajs/test-utils": "2.15.3",
    "@medusajs/ui": "4.1.13"
  },
  "engines": {
    "node": ">=20"
  },
  "types": "./.medusa/server/src/index.d.ts"
}
